font-family = "BerkeleyMono Nerd Font"
theme = "dark:OKSolar Dark Colorblind,light:OKSolar Light Colorblind"
# Auto-bump any near-invisible text to a legible contrast ratio (1 = off).
minimum-contrast = 1.1
command = "/usr/local/bin/nu --config ~/.config/nushell/config.nu"
keybind = shift+enter=text:\x1b\r
window-subtitle = false
window-theme = ghostty
window-decoration = auto
title = " "
macos-titlebar-proxy-icon = hidden
cursor-style = block_hollow
keybind = global:cmd+backquote=toggle_quick_terminal
quick-terminal-size = 60%
quick-terminal-position = center