# vim: ft=dosini
#
# aerc styleset — Github Light Colorblind
# Auto-generated to match the ghostty theme "Github Light Colorblind"
# (~/.config/ghostty/themes/Github Light Colorblind). See aerc-stylesets(7).

*.default=true
*.normal=true
*.fg=#24292f
*.bg=#ffffff

# Cursor / selected row — uses the theme's terminal selection pair
*.selected.fg=#ffffff
*.selected.bg=#24292f

# Status messages
error.fg=#b35900
error.bold=true
warning.fg=#633c01
success.fg=#0550ae

# Title bars & section headers
title.fg=#ffffff
title.bg=#0969da
title.bold=true
header.fg=#0969da
header.bold=true

# Panel borders
border.fg=#57606a
border.bg=#ffffff

# Status line (bottom bar)
statusline_default.fg=#ffffff
statusline_default.bg=#24292f
statusline_error.fg=#ffffff
statusline_error.bg=#b35900
statusline_success.fg=#ffffff
statusline_success.bg=#0550ae

# Directory (folder) list
dirlist_default.fg=#24292f
dirlist_unread.fg=#0969da
dirlist_unread.bold=true
dirlist_recent.fg=#0550ae

# Message list
msglist_default.fg=#24292f
msglist_unread.fg=#0969da
msglist_unread.bold=true
msglist_unread.selected.fg=#ffffff
msglist_unread.selected.bg=#0969da
msglist_flagged.fg=#8250df
msglist_flagged.bold=true
msglist_deleted.fg=#57606a
msglist_deleted.dim=true
msglist_marked.fg=#ffffff
msglist_marked.bg=#8250df
msglist_marked.selected.fg=#ffffff
msglist_marked.selected.bg=#8250df
msglist_result.fg=#633c01
msglist_result.bold=true
msglist_thread_folded.fg=#0969da
msglist_thread_context.fg=#57606a
msglist_thread_context.dim=true
msglist_thread_orphan.fg=#633c01
msglist_gutter.bg=#ffffff
msglist_pill.fg=#ffffff
msglist_pill.bg=#0969da

# Attachment / part switcher
part_switcher.bg=#ffffff
part_filename.fg=#24292f
part_mimetype.fg=#57606a

# Command completion popover
completion_default.fg=#ffffff
completion_default.bg=#24292f
completion_default.selected.fg=#ffffff
completion_default.selected.bg=#0969da
completion_gutter.bg=#24292f
completion_pill.fg=#ffffff
completion_pill.bg=#0969da
completion_description.fg=#57606a

# Tab bar
tab.fg=#57606a
tab.bg=#ffffff
tab.selected.fg=#ffffff
tab.selected.bg=#0969da
tab.selected.bold=true

# Selector dialogs
selector_default.fg=#24292f
selector_focused.fg=#ffffff
selector_focused.bg=#0969da
selector_chooser.fg=#0969da
selector_chooser.bold=true

# Loading spinner
spinner.fg=#0969da

[viewer]
*.default=true
*.normal=true
*.fg=#24292f
*.bg=#ffffff

header.fg=#8250df
header.bold=true
signature.fg=#57606a
signature.dim=true
url.fg=#0969da
url.underline=true

diff_meta.fg=#24292f
diff_meta.bold=true
diff_chunk.fg=#1b7c83
diff_chunk_func.fg=#1b7c83
diff_chunk_func.dim=true
diff_add.fg=#0550ae
diff_del.fg=#b35900

quote_1.fg=#0969da
quote_2.fg=#1b7c83
quote_3.fg=#8250df
quote_4.fg=#8250df
quote_x.fg=#57606a
quote_x.dim=true
